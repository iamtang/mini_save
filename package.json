{
  "name": "mini_save",
  "version": "1.2.6",
  "description": "迷你保存",
  "main": "index.js",
  "scripts": {
    "dev": "electron .",
    "start": "electron-builder --dir",
    "publish": "electron-builder --publish always",
    "clean": "electron-builder --clear-cache",
    "package": "NODE_ENV=production electron-builder --mac",
    "package-win": "set NODE_ENV=production && electron-builder --win",
    "release": "node lib/electron-updater.js release"
  },
  "author": "iamtang",
  "license": "ISC",
  "dependencies": {
    "ali-oss": "^6.23.0",
    "axios": "^1.7.9",
    "electron-log": "^5.2.4",
    "express": "^4.21.2",
    "form-data": "^4.0.4",
    "multer": "^1.4.5-lts.1",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "electron": "^34.5.8",
    "electron-builder": "^25.1.8"
  },
  "build": {
    "extraMetadata": {
      "publish": {
        "provider": "github",
        "owner": "iamtang",
        "repo": "mini_save"
      }
    },
    "productName": "迷你保存",
    "asar": true,
    "compression": "maximum",
    "files": [
      "dist/**/*",
      "page/**/*",
      "icons/**/*",
      "index.js",
      "main.js",
      "server.js",
      "onCopy.js",
      "lib/electron-updater.js",
      "utils.js",
      "clipboard.js",
      "config.json",
      "package.json"
    ],
    "win": {
      "icon": "icons/logo.ico"
    },
    "mac": {
      "icon": "icons/logo.icns",
      "target": [
        "dmg"
      ]
    },
    "directories": {
      "output": "build-output"
    }
  }
}
